{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CleanArchDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_STRONG_SECRET_KEY_WITH_AT_LEAST_32_CHARS",
    "Issuer": "CleanArch.Api",
    "Audience": "CleanArch.Client",
    "ExpirationInMinutes": 60
  },
  "AWS": {
    "Region": "us-east-1"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
